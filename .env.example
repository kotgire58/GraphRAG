# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Neo4j (Aura Cloud)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# LLM (OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-your-key-here
LLM_CHOICE=openai/gpt-4.1-mini
INGESTION_LLM_CHOICE=openai/gpt-4.1-nano

# Embeddings (OpenRouter)
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=sk-or-v1-your-key-here
EMBEDDING_MODEL=openai/text-embedding-3-small
VECTOR_DIMENSION=1536

# App
APP_HOST=0.0.0.0
APP_PORT=8058
LOG_LEVEL=INFO
# Comma-separated origins for browser CORS (add your Render static site URL in production).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite) — set at build time on Render Static Site; full URL of the Web Service, no trailing slash.
# VITE_API_BASE_URL=https://your-api-service.onrender.com

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150
